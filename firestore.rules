rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownerUid() {
      return "roduqZRk4GgXLCQIZGIFAWN0UUg1";
    }

    function isOwner() {
      return signedIn() && request.auth.uid == ownerUid();
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() ? userDoc().data.role : "user";
    }

    function isAdmin() {
      return signedIn() && (isOwner() || userRole() == "admin");
    }

    function isModerator() {
      return signedIn() && (isAdmin() || userRole() == "moderator");
    }

    function isSupport() {
      return signedIn() && (isModerator() || userRole() == "support");
    }

    function isOwnerUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeUserUpdate(userId) {
      return isOwnerUser(userId)
        && !request.resource.data.diff(resource.data)
          .changedKeys()
          .hasAny([
            "role",
            "verified",
            "creator",
            "trusted",
            "vip",
            "team",
            "partner",
            "company",
            "isBanned",
            "isDeleted",
            "trustScore",
            "reportedCount",
            "riskFlags",
            "creatorLevel",
            "creatorPending",
            "verificationPending",
            "ageVerified",
            "identityVerified"
          ]);
    }

    function isActivityCreator(activityId) {
      return signedIn()
        && get(/databases/$(database)/documents/activities/$(activityId))
          .data.creatorId == request.auth.uid;
    }

    function isActivityParticipant(activityId) {
      return signedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/activities/$(activityId)
        ).data.participants;
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwnerUser(userId);

      allow update: if
        isOwner()
        || isAdmin()
        || safeUserUpdate(userId);

      allow delete: if isOwner();
    }

    match /activities/{activityId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.creatorId == request.auth.uid;

      allow update: if
        isModerator()
        || resource.data.creatorId == request.auth.uid
        || (
          signedIn()
          && request.resource.data.diff(resource.data)
            .changedKeys()
            .hasOnly([
              "participants",
              "pendingRequests",
              "spotsLeft",
              "updatedAt"
            ])
        );

      allow delete: if
        isModerator()
        || resource.data.creatorId == request.auth.uid;

      match /chat/{messageId} {
        allow read: if isActivityParticipant(activityId);

        allow create: if
          isActivityParticipant(activityId)
          && request.resource.data.senderId == request.auth.uid;

        allow update, delete: if isModerator();
      }
    }

    match /privateChats/{chatId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;

      allow delete: if isModerator();

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(
            /databases/$(database)/documents/privateChats/$(chatId)
          ).data.participants;

        allow create: if signedIn()
          && request.auth.uid in get(
            /databases/$(database)/documents/privateChats/$(chatId)
          ).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.receiverId is string
          && request.resource.data.text is string
          && request.resource.data.createdAt is timestamp;

        allow update: if isModerator();

        allow delete: if isModerator();
      }
    }

    match /stories/{storyId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.uid == request.auth.uid ||
          request.resource.data.creatorId == request.auth.uid ||
          request.resource.data.ownerId == request.auth.uid
        );

      allow update: if signedIn()
        && request.resource.data.diff(resource.data)
          .changedKeys()
          .hasOnly([
            "views",
            "likes",
            "updatedAt"
          ]);

      allow delete: if
        isModerator()
        || resource.data.userId == request.auth.uid
        || resource.data.uid == request.auth.uid
        || resource.data.creatorId == request.auth.uid
        || resource.data.ownerId == request.auth.uid;
    }

    match /moments/{momentId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.imageUrl is string
        && request.resource.data.type in ["photo", "video"]
        && request.resource.data.likes is list;

      allow update: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isModerator()
          || request.resource.data.diff(resource.data)
            .changedKeys()
            .hasOnly([
              "likes",
              "views",
              "updatedAt"
            ])
        );

      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isModerator()
        );
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reportedBy == request.auth.uid;

      allow read, update, delete: if isModerator();
    }

    match /support/{supportId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;

      allow read: if isSupport()
        || (
          signedIn()
          && resource.data.uid == request.auth.uid
        );

      allow update, delete: if isSupport();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && (
          resource.data.toUserId == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          isSupport()
        );

      allow create: if signedIn();

      allow update: if signedIn()
        && (
          resource.data.toUserId == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          isSupport()
        );

      allow delete: if isModerator();
    }

    match /adminLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}